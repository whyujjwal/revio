# ─── Local development ──────────────────────────────────────────────
# Copy this to apps/api/.env for running the backend outside Docker.

# App
APP_NAME=Revio API
APP_VERSION=0.1.0
DEBUG=false

# Database
# Local SQLite (default for quick start):
DATABASE_URL=sqlite:///./dev.db
# Docker Compose Postgres:
# DATABASE_URL=postgresql+psycopg2://revio:revio@localhost:5432/revio
# Railway Postgres (auto-injected, postgresql:// is auto-converted):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# AI Memory (ChromaDB local vector DB — no API key needed)
MEMORY_DB_PATH=.data/chromadb

# Admin Auth
ADMIN_EMAIL=admin@revio.com
ADMIN_PASSWORD=changeme
SECRET_KEY=changeme-secret-key

# OpenAI
OPENAI_API_KEY=

# Resume Storage
RESUME_STORAGE_PATH=.data/resumes

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# CORS — comma-separated list of allowed origins
# Railway: set to your Vercel frontend URL
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
